# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aspire_user
DB_PASSWORD=aspire_dev
DB_DATABASE=aspire_endoexpertise
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_SSL=false

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# OAuth2 / Identity Provider
OAUTH2_ISSUER_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_CALLBACK_URL=http://localhost:3001/api/v1/auth/callback

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_EVIDENCE=evidence-uploads
AZURE_STORAGE_CONTAINER_VIDEOS=surgical-videos
AZURE_STORAGE_CONTAINER_DOCUMENTS=patient-documents

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Application
API_PREFIX=api/v1
PORT=3001
