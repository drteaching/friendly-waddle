# =============================================================================
# ASPIRE EndoExpertise Platform - Environment Configuration
# =============================================================================

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aspire_user
DB_PASSWORD=change_me_in_production
DB_DATABASE=aspire_endoexpertise
DB_SSL=false
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# JWT Authentication
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# OAuth2 / Identity Provider
OAUTH2_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_CALLBACK_URL=http://localhost:3001/api/v1/auth/callback

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_EVIDENCE=evidence-uploads
AZURE_STORAGE_CONTAINER_VIDEOS=surgical-videos
AZURE_STORAGE_CONTAINER_DOCUMENTS=patient-documents

# Azure AI Services
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Email / Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=noreply@endoexpertise.org.au
